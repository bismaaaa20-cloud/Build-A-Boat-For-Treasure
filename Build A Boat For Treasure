-- 1. KONFIGURASI AWAL
local Stages = game:GetService("Workspace").BoatStages.NormalStages
local client = game:GetService("Players").LocalPlayer
local cfg = getgenv().Config or {}
cfg.Setting_Farm = cfg.Setting_Farm or {}
cfg.Anti_AFK = cfg.Anti_AFK or {}
cfg.Webhook = cfg.Webhook or {}

local autoFarm = cfg.Setting_Farm.Auto_Farm ~= false
local fpsBoost = cfg.Setting_Farm.FPS_Boost == true
local antiAfk = cfg.Anti_AFK.Enable ~= false
local webhookUrl = cfg.Webhook.UrlWebhook or ""

if game:GetService("CoreGui"):FindFirstChild("BABFT_UltimateTracker") then
    game:GetService("CoreGui").BABFT_UltimateTracker:Destroy()
end

-- 2. FPS BOOST
if fpsBoost then
    task.spawn(function()
        for _, v in pairs(workspace:GetDescendants()) do
            if v:IsA("Part") or v:IsA("CornerWedgePart") then v.Material = Enum.Material.SmoothPlastic end
            if v:IsA("Decal") or v:IsA("Texture") then v:Destroy() end
        end
        game:GetService("Lighting").GlobalShadows = false
    end)
end

-- 3. ANTI-AFK
if antiAfk then
    local VirtualUser = game:GetService("VirtualUser")
    client.Idled:Connect(function() VirtualUser:CaptureController(); VirtualUser:ClickButton2(Vector2.new(0,0)) end)
end

-- 4. GUI & PANEL
local screenGui = Instance.new("ScreenGui", game:GetService("CoreGui"))
screenGui.Name = "BABFT_UltimateTracker"
local MainFrame = Instance.new("Frame", screenGui)
MainFrame.Size = UDim2.new(0, 290, 0, 240); MainFrame.Position = UDim2.new(0.5, -145, 0.5, -120)
MainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30); MainFrame.Active = true; MainFrame.Draggable = true

local TitleBar = Instance.new("TextLabel", MainFrame)
TitleBar.Size = UDim2.new(1, 0, 0, 40); TitleBar.BackgroundColor3 = Color3.fromRGB(230, 126, 34)
TitleBar.Text = "AFK FARM MING"; TitleBar.TextColor3 = Color3.fromRGB(255, 255, 255); TitleBar.Font = Enum.Font.GothamBold

local ScrollFrame = Instance.new("ScrollingFrame", MainFrame)
ScrollFrame.Size = UDim2.new(1, -20, 1, -55); ScrollFrame.Position = UDim2.new(0, 10, 0, 50)
ScrollFrame.BackgroundTransparency = 1; ScrollFrame.CanvasSize = UDim2.new(0, 0, 0, 200)

local yPos = 0
local function CreateLabel(text, color)
    local label = Instance.new("TextLabel", ScrollFrame)
    label.Size = UDim2.new(1, 0, 0, 30); label.Position = UDim2.new(0, 0, 0, yPos); label.BackgroundTransparency = 1
    label.Text = text; label.TextColor3 = color; label.TextXAlignment = Enum.TextXAlignment.Left; label.TextSize = 14
    yPos = yPos + 30
    return label
end
local TimerLabel = CreateLabel("Session: 00:00:00", Color3.fromRGB(255, 255, 255))
local GoldLabel = CreateLabel("Gold: 0", Color3.fromRGB(46, 204, 113))

-- 5. ENGINE UTAMA, TELEPORT & WEBHOOK
local StartTime, totalGold = os.time(), 0
task.spawn(function()
    while autoFarm do
        task.wait(600) -- Webhook (Telepon) tiap 10 menit
        if webhookUrl ~= "" then
            local msg = {["content"] = "User: " .. client.Name .. " | Total Gold: " .. totalGold}
            request({Url = webhookUrl, Method = "POST", Headers = {["content-type"] = "application/json"}, Body = game:GetService("HttpService"):JSONEncode(msg)})
        end
    end
end)

task.spawn(function()
    while autoFarm do
        task.wait(1)
        if client.Character and client.Character:FindFirstChild("HumanoidRootPart") then
            local elapsed = os.time() - StartTime
            TimerLabel.Text = string.format("Session: %02d:%02d:%02d", math.floor(elapsed/3600), math.floor((elapsed%3600)/60), elapsed%60)
            
            -- TELEPORTASI KE STAGE 9
            local stage9 = Stages:FindFirstChild("CaveStage9")
            if stage9 and stage9:FindFirstChild("DarknessPart") then
                client.Character.HumanoidRootPart.CFrame = stage9.DarknessPart.CFrame
                
                -- KLAIM GOLD
                local goldEvent = workspace:FindFirstChild("ClaimRiverResultsGold")
                if goldEvent then 
                    goldEvent:FireServer(); 
                    totalGold = totalGold + 16; 
                    GoldLabel.Text = "Gold: " .. totalGold 
                end
            end
        end
    end
end)
